{
  "name": "social-commerce",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manhha5842/Social-Commerce.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/manhha5842/Social-Commerce/issues"
  },
  "homepage": "https://github.com/manhha5842/Social-Commerce#readme",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web dev:worker",
    "dev:api": "npm run dev --workspace @social-commerce/api",
    "dev:web": "npm run dev --workspace @social-commerce/web",
    "dev:worker": "npm run dev --workspace @social-commerce/worker",
    "build": "npm-run-all build:api build:web build:worker",
    "build:api": "npm run build --workspace @social-commerce/api",
    "build:web": "npm run build --workspace @social-commerce/web",
    "build:worker": "npm run build --workspace @social-commerce/worker",
    "db:generate": "npm run prisma:generate --workspace @social-commerce/database",
    "db:migrate": "npm run prisma:migrate --workspace @social-commerce/database"
  }
}